$kind: http-request
name: 'Create User'
url: '{{baseUrl}}/users'
method: POST
headers:
  - key: Content-Type
    value: application/json
body:
  type: json
  content: |-
    {
      "name": "{{userName}}",
      "email": "{{userEmail}}",
      "password": "{{userPassword}}"
    }
order: 1775745011719
